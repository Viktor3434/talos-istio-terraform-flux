# AUTOGENERATED BY 01-talos-test-stand-up. DO NOT EDIT MANUALLY.

ISO_PATH = File.expand_path("/home/viktor/ISO-images/metal-amd64.iso")
STORAGE_POOL = "pool-talos"

Vagrant.configure("2") do |config|
  config.vm.synced_folder ".", "/vagrant", disabled: true

  # Control Plane nodes
  
  config.vm.define "talos-cp-1" do |node|
    node.vm.provider :libvirt do |lv|
      lv.default_prefix = ""
      lv.memory = 6144
      lv.cpus = 2
      lv.storage :file, :device => :cdrom, :path => ISO_PATH
      lv.storage_pool_name = STORAGE_POOL
      lv.storage :file, :size => '40G', :name => "talos-cp-1.qcow2"
      lv.boot 'hd'
      lv.boot 'cdrom'
    end
  end
  

  # Worker nodes
  
  config.vm.define "talos-worker-1" do |node|
    node.vm.provider :libvirt do |lv|
      lv.default_prefix = ""
      lv.memory = 8192
      lv.cpus = 6
      lv.storage :file, :device => :cdrom, :path => ISO_PATH
      lv.storage_pool_name = STORAGE_POOL
      lv.storage :file, :size => '40G', :name => "talos-worker-1.qcow2"
      lv.boot 'hd'
      lv.boot 'cdrom'
    end
  end
  
end