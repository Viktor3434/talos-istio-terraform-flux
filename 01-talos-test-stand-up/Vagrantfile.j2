# -*- mode: ruby -*-
# vi: set ft=ruby :
# AUTOGENERATED BY 01-talos-test-stand-up. DO NOT EDIT MANUALLY.

ISO_PATH = File.expand_path("{{ iso_path }}")
STORAGE_POOL = "{{ pool_disks_name }}"

Vagrant.configure("2") do |config|
  config.vm.synced_folder ".", "/vagrant", disabled: true

  # Control Plane nodes
  {% for i in range(1, control_planes_count + 1) %}
  config.vm.define "talos-cp-{{ i }}" do |node|
    node.vm.provider :libvirt do |lv|
      lv.default_prefix = ""
      lv.memory = {{ cp_memory | default(4096) }}
      lv.cpus = {{ cp_cpus | default(4) }}
      lv.storage :file, :device => :cdrom, :path => ISO_PATH
      lv.storage_pool_name = STORAGE_POOL
      lv.storage :file, :size => '{{ disk_size | default("40G") }}', :name => "talos-cp-{{ i }}.qcow2"
      lv.boot 'hd'
      lv.boot 'cdrom'
    end
  end
  {% endfor %}

  # Worker nodes
  {% for i in range(1, workers_count + 1) %}
  config.vm.define "talos-worker-{{ i }}" do |node|
    node.vm.provider :libvirt do |lv|
      lv.default_prefix = ""
      lv.memory = {{ worker_memory | default(4096) }}
      lv.cpus = {{ worker_cpus | default(4) }}
      lv.storage :file, :device => :cdrom, :path => ISO_PATH
      lv.storage_pool_name = STORAGE_POOL
      lv.storage :file, :size => '{{ disk_size | default("40G") }}', :name => "talos-worker-{{ i }}.qcow2"
      lv.boot 'hd'
      lv.boot 'cdrom'
    end
  end
  {% endfor %}
end